<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TicTacToe.MainPage">

    <Grid RowDefinitions="Auto,Auto,300,Auto">
        <Label Grid.Row="0" Text="Tmavý režim"/>
        <StackLayout Grid.Row="1" Orientation="Horizontal" Padding="10,5">
            <RadioButton Content="Světlý" GroupName="Theme" IsChecked="{Binding LightTheme}"/>
            <RadioButton Content="Tmavý" GroupName="Theme"/>
        </StackLayout>
        <Grid Grid.Row="2"
              RowDefinitions="*,*,*"
              ColumnDefinitions="*,*,*"
              Padding="10"
              BackgroundColor="Gray"
              WidthRequest="{Binding Height, Source={x:Reference GameGrid}}" x:Name="GameGrid">

            <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource CellButtonStyle}"/>
            <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource CellButtonStyle}"/>
            <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource CellButtonStyle}"/>
            <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource CellButtonStyle}"/>
            <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource CellButtonStyle}"/>
            <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource CellButtonStyle}"/>
            <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource CellButtonStyle}"/>
            <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource CellButtonStyle}"/>
            <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource CellButtonStyle}"/>
        </Grid>

        <Button Grid.Row="3" Style="{StaticResource NewGameButtonStyle}"/>
    </Grid>
</ContentPage>
