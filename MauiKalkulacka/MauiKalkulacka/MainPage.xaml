<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiKalkulacka.MainPage">

    <Grid RowDefinitions="*,7*">

        <Border Stroke="Black"
                StrokeThickness="3"
                StrokeShape="RoundRectangle 10">
            <Label x:Name="DisplayLabel"
                   Text="0"
                   FontSize="40"
                   HorizontalOptions="End"
                   VerticalOptions="Center"
                   BackgroundColor="AliceBlue"
                   Padding="20"/>
        </Border>

        <Grid Grid.Row="1"
              BackgroundColor="AliceBlue"
              RowDefinitions="*,*,*,*,*"
              ColumnDefinitions="*,*,*,*">

            <!-- 1. řádek -->
            <Button Text="7" Grid.Row="0" Grid.Column="0" Margin="10" Clicked="OnNumberClicked"/>
            <Button Text="8" Grid.Row="0" Grid.Column="1" Margin="10" Clicked="OnNumberClicked"/>
            <Button Text="9" Grid.Row="0" Grid.Column="2" Margin="10" Clicked="OnNumberClicked"/>
            <Button Text="÷" Grid.Row="0" Grid.Column="3" Margin="10" Clicked="OnOperatorClicked"/>

            <!-- 2. řádek -->
            <Button Text="4" Grid.Row="1" Grid.Column="0" Margin="10" Clicked="OnNumberClicked"/>
            <Button Text="5" Grid.Row="1" Grid.Column="1" Margin="10" Clicked="OnNumberClicked"/>
            <Button Text="6" Grid.Row="1" Grid.Column="2" Margin="10" Clicked="OnNumberClicked"/>
            <Button Text="×" Grid.Row="1" Grid.Column="3" Margin="10" Clicked="OnOperatorClicked"/>

            <!-- 3. řádek -->
            <Button Text="1" Grid.Row="2" Grid.Column="0" Margin="10" Clicked="OnNumberClicked"/>
            <Button Text="2" Grid.Row="2" Grid.Column="1" Margin="10" Clicked="OnNumberClicked"/>
            <Button Text="3" Grid.Row="2" Grid.Column="2" Margin="10" Clicked="OnNumberClicked"/>
            <Button Text="−" Grid.Row="2" Grid.Column="3" Margin="10" Clicked="OnOperatorClicked"/>

            <!-- 4. řádek -->
            <Button Text="0" Grid.Row="3" Grid.Column="0" Margin="10" Clicked="OnNumberClicked"/>
            <Button Text="C" Grid.Row="3" Grid.Column="1" Margin="10" Clicked="OnClearClicked"/>
            <Button Text="=" Grid.Row="3" Grid.Column="2" Margin="10" Clicked="OnEqualsClicked"/>
            <Button Text="+" Grid.Row="3" Grid.Column="3" Margin="10" Clicked="OnOperatorClicked"/>

        </Grid>

    </Grid>

</ContentPage>
