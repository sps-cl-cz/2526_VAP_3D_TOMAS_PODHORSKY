<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="MauiPiskvorky.Styles.Style">

    <!-- Stavový displej -->
    <Style TargetType="Label" x:Key="ResultLabelStyle">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light=Black, Dark=White}" />
    </Style>

    <Style TargetType="Button" x:Key="CellButtonStyle">
        <Setter Property="FontSize" Value="48"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="TextColor" Value="Black"/>
        <Setter Property="Background" Value="{AppThemeBinding Light=#DDDDDD, Dark=#444444}"/>
    </Style>

    <Style TargetType="Button" x:Key="NewGameButtonStyle" BasedOn="{StaticResource CellButtonStyle}">
        <Setter Property="FontSize" Value="25"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="Background" Value="Green"/>
        <Setter Property="Margin" Value="5,10,5,5"/>
    </Style>

</ResourceDictionary>
