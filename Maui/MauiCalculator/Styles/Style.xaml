<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiCalculator.Styles.Style">
    <Style TargetType="Label" x:Key="ResultLabelStyle">
        <Setter Property="FontSize" Value="40" />
        <Setter Property="HorizontalOptions" Value="End" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="Margin" Value="0,0,20,0" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="White" />
    </Style>
    <Style TargetType="Button" x:Key="ButtonStyle">
        <Setter Property="FontSize" Value="25"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="{AppThemeBinding Light={StaticResource LightButtonColor}, Dark={StaticResource DarkButtonColor}}"/>
    </Style>
    <Style TargetType="Button" x:Key="EqualButtonStyle" BasedOn="{StaticResource ButtonStyle}">
        <Setter Property="Background" Value="Green"/>
    </Style>
    <Style TargetType="Button" x:Key="ClearButtonStyle" BasedOn="{StaticResource ButtonStyle}">
        <Setter Property="Background" Value="Orange"/>
    </Style>
</ResourceDictionary>