<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectManager.Controls.ImagePicker"
             xmlns:local="clr-namespace:ProjectManager.Controls">
    <HorizontalStackLayout>
        <Label Text="Obrázek: " Style="{StaticResource ImageLabelStyle}"/>
        <Image Source="{Binding ImagePath, Source={RelativeSource AncestorType={x:Type local:ImagePicker}}}" HeightRequest="40" Aspect="AspectFill" Margin="0,0,10,0"/>
        <Button Text="Vybrat obrázek" Clicked="FileSelect_Clicked" Style="{StaticResource SecondaryButtonStyle}" />
    </HorizontalStackLayout>
</ContentView>
