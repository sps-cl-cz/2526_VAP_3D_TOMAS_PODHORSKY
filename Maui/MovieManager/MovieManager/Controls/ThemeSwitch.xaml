<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectManager.Controls.ThemeSwitch"
             x:Name="this">

    <StackLayout Orientation="{Binding Orientation, Source={x:Reference this}}"
                 Spacing="10"
                 Padding="{Binding Margin, Source={x:Reference this}}">

        <Label Text="{Binding Text, Source={x:Reference this}}"
               VerticalOptions="Center"
               FontAttributes="Bold" />

        <Switch IsToggled="{Binding IsDarkMode, Source={x:Reference this}}"
                Toggled="OnThemeToggled"
                VerticalOptions="Center" />

    </StackLayout>
</ContentView>