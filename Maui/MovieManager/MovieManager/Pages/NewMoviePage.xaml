<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectManager.Pages.NewMoviePage"
             xmlns:c="clr-namespace:ProjectManager.Controls"
             Title="Přidání filmu">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            <Frame Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Název" Style="{StaticResource FormLabelStyle}" />
                    <Entry x:Name="MovieTitle" Placeholder="Zadejte název filmu" Style="{StaticResource FormEntryStyle}" />

                    <Label Text="Popis" Style="{StaticResource FormLabelStyle}" />
                    <Entry x:Name="MovieDescription" Placeholder="Krátký popis filmu" Style="{StaticResource FormEntryStyle}" />

                    <Label Text="Rok" Style="{StaticResource FormLabelStyle}" />
                    <Entry x:Name="MovieYear" Placeholder="Např. 2024" Keyboard="Numeric" Style="{StaticResource FormEntryStyle}" />

                    <Label Text="Žánr" Style="{StaticResource FormLabelStyle}" />
                    <Entry x:Name="MovieGenre" Placeholder="Např. Drama, Akce, Komedie..." Style="{StaticResource FormEntryStyle}" />

                    <Label Text="Hodnocení (0–10)" Style="{StaticResource FormLabelStyle}" />
                    <Entry x:Name="MovieRating" Placeholder="Např. 8.5" Keyboard="Numeric" Style="{StaticResource FormEntryStyle}" />

                    <c:ImagePicker ImagePath="{Binding Icon}" />
                </VerticalStackLayout>
            </Frame>
            <Button Text="Přidat film" Clicked="Button_Clicked" Style="{StaticResource PrimaryButtonStyle}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
