<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectManager.MainPage"
             Title="Seznam filmů">
    <ListView ItemsSource="{Binding Movies}" ItemTapped="ListView_ItemTapped" SeparatorVisibility="None" HasUnevenRows="True">
        <ListView.ItemTemplate>
            <DataTemplate>
                <ViewCell>
                    <Frame Style="{StaticResource CardStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                            <Image Grid.Column="0" Source="{Binding Icon}" HeightRequest="60" WidthRequest="60" Aspect="AspectFill" Margin="0,0,12,0"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <Label Text="{Binding Title}" Style="{StaticResource TitleLabelStyle}" />
                                <Label Text="{Binding Rating, StringFormat='⭐ {0:F1} / 10'}" Style="{StaticResource RatingLabelStyle}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="2" Text="Odebrat" Style="{StaticResource DeleteButtonStyle}" Clicked="Button_Clicked"/>
                        </Grid>
                    </Frame>
                </ViewCell>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
</ContentPage>
