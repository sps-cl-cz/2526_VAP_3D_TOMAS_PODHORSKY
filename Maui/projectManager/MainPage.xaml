<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectManager.MainPage">

    <ListView ItemsSource="{Binding Projects}" ItemTapped="ListView_ItemTapped">
        <ListView.ItemTemplate>
            <DataTemplate>
                <ViewCell>
                    <Grid ColumnDefinitions="*,*,*">
                        <Label Text="{Binding Title}"/>
                        <Label Text="{Binding Date}" Grid.Column="1"/>
                        <Button Text="Odstranit" Clicked="Button_Clicked" CommandParameter="{Binding}" Grid.Column="2"/>
                    </Grid>
                </ViewCell>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>

</ContentPage>
