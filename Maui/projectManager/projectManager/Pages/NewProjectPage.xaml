<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="projectManager.Pages.NewProjectPage">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Entry x:Name="ProjectTitle" Placeholder="Title"/>
        <Entry x:Name="ProjectDescription" Placeholder="Description"/>
        <DatePicker x:Name="ProjectDate"/>
        <Button Text="Create Project" Clicked="Button_Clicked"/>
    </VerticalStackLayout>
</ContentPage>