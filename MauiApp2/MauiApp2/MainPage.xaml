<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui_kalkulacka.MainPage">

    <Grid RowDefinitions="*,7*">

        <Border Stroke="Black">
            <Border.StrokeThickness>
                <x:Double>3</x:Double>
            </Border.StrokeThickness>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10"/>
            </Border.StrokeShape>
            <Label Text="0" BackgroundColor="AliceBlue"/>
        </Border>

        <Grid Grid.Row="1"
              BackgroundColor="AliceBlue"
              RowDefinitions="*,*,*,*"
              ColumnDefinitions="*,*,*">

            <Button Text="7" Grid.Row="0" Grid.Column="0" Margin="10"/>
            <Button Text="8" Grid.Row="0" Grid.Column="1" Margin="10"/>
            <Button Text="9" Grid.Row="0" Grid.Column="2" Margin="10"/>

            <Button Text="4" Grid.Row="1" Grid.Column="0" Margin="10"/>
            <Button Text="5" Grid.Row="1" Grid.Column="1" Margin="10"/>
            <Button Text="6" Grid.Row="1" Grid.Column="2" Margin="10"/>

            <Button Text="1" Grid.Row="2" Grid.Column="0" Margin="10"/>
            <Button Text="2" Grid.Row="2" Grid.Column="1" Margin="10"/>
            <Button Text="3" Grid.Row="2" Grid.Column="2" Margin="10"/>

            <Button Text="=" Grid.Row="3" Grid.Column="2" Margin="10"/>
        </Grid>

    </Grid>

</ContentPage>
