<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MujFiltr"
             x:Class="MujFiltr.MainPage">

    <VerticalStackLayout Padding="30" Spacing="20">

        <Label Text="Můj školní sklad" FontSize="24" HorizontalOptions="Center" FontAttributes="Bold" />

        <local:FilteredSearchBar x:Name="MujHledac" 
                                 Placeholder="Hledej podle názvu..." 
                                 Filter="Nazev" />

        <ListView x:Name="Seznam" ItemsSource="{Binding Source={x:Reference MujHledac}, Path=FilteredItems}" HasUnevenRows="True">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <VerticalStackLayout Padding="10">
                            <Label Text="{Binding Nazev}" FontSize="18" FontAttributes="Bold" />
                            <Label Text="{Binding Kategorie}" FontSize="14" TextColor="Gray" />
                        </VerticalStackLayout>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </VerticalStackLayout>

</ContentPage>