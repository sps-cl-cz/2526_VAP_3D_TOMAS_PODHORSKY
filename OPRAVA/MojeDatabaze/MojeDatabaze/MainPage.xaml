<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MojeDatabaze.MainPage">

    <VerticalStackLayout Padding="30" Spacing="20">

        <Label Text="Databáze poznámek" FontSize="24" HorizontalOptions="Center" FontAttributes="Bold" />

        <Entry x:Name="VstupniText" Placeholder="Napiš novou poznámku..." />

        <Button Text="Uložit do databáze" Clicked="Ulozit_Clicked" BackgroundColor="#512BD4" TextColor="White" />

        <ListView x:Name="SeznamPoznamek" HasUnevenRows="True">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Label Text="{Binding Text}" FontSize="18" Padding="10" />
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </VerticalStackLayout>

</ContentPage>